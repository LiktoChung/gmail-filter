# Google Cloud OAuth (Gmail API) — Web application client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match Authorized redirect URIs in Google Cloud Console
REDIRECT_URI=http://localhost:8000/api/auth/callback

# Optional override (default /data in Docker)
# DATA_DIR=/data

# Gmail throughput (optional; defaults are conservative for per-minute quota)
# GMAIL_LIST_PAGE_SIZE=500
# GMAIL_PARALLEL_WORKERS=4
# GMAIL_HTTP_TIMEOUT_SECONDS=300
# GMAIL_ENRICH_CHUNK_SIZE=8
# GMAIL_SYNC_CHUNK_PAUSE_SECONDS=0.75
# GMAIL_LIST_PAGE_PAUSE_SECONDS=0.35
# GMAIL_RETRY_INITIAL_DELAY_SECONDS=2
# GMAIL_RETRY_MAX_DELAY_SECONDS=120
# GMAIL_RETRY_MAX_ATTEMPTS=12
